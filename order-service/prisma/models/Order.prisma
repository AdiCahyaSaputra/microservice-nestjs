model Order {
  id           String      @id @default(uuid())
  customerName String      @db.VarChar(100)
  item         String      @db.VarChar(200)
  quantity     Int         @default(1)
  status       OrderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}
